{
  "name": "durgasos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "overrides": {
    "postcss": "^8.5.14",
    "react-motion": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postbuild": "node scripts/copy-standalone-assets.mjs",
    "icons:generate": "node scripts/generate-pwa-icons.mjs",
    "dev:electron": "concurrently -k \"next dev\" \"wait-on http://127.0.0.1:3000 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:prep": "node scripts/copy-standalone-assets.mjs",
    "build:electron": "next build && node scripts/copy-standalone-assets.mjs && electron-builder",
    "make:win": "next build && node scripts/copy-standalone-assets.mjs && electron-builder --win",
    "make:mac": "next build && node scripts/copy-standalone-assets.mjs && electron-builder --mac",
    "make:linux": "next build && node scripts/copy-standalone-assets.mjs && electron-builder --linux",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "clean": "node scripts/clean.mjs",
    "clean:all": "node scripts/clean.mjs --all",
    "codegen": "node scripts/codegen.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "css:inventory": "node scripts/css-inventory.mjs",
    "check:best-practices": "node scripts/check-best-practices.mjs",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run css:inventory && npm run check:best-practices && npm run build",
    "postinstall": "node scripts/patch-react-motion.mjs"
  },
  "dependencies": {
    "@apollo/client": "^4.1.9",
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@google/genai": "^2.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@xyflow/react": "^12.10.2",
    "autoprefixer": "^10.5.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "framer-motion": "^12.40.0",
    "graphql": "^16.14.0",
    "lucide-react": "^1.16.0",
    "monaco-editor": "^0.55.1",
    "next": "^16.2.6",
    "pdfjs-dist": "^5.7.284",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-motion": "^0.5.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-motion": "^0.0.40",
    "@types/wait-on": "^5.3.4",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "ai.thekoushikdurgas.durgasos",
    "productName": "DurgasOS",
    "copyright": "Copyright © DurgasOS",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}

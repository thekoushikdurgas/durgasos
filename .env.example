# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ai.backend integration (see lib/backend-url.ts + next.config.ts)
#
# Unlike Contact360 (dev-only /graphql rewrite to avoid CORS), DurgasOS calls GraphQL and
# WebSocket directly from the browser. Ensure ai.backend CORS_ORIGINS includes this app
# (e.g. http://localhost:3000 and http://127.0.0.1:3000). Auth session cookies stay
# same-origin via app/api/auth/session.
#
# Env resolution order for /files/* rewrites: NEXT_PUBLIC_BACKEND_URL → origin of
# NEXT_PUBLIC_GRAPHQL_URL → http://localhost:8000 in development only.
# Do not point either URL at :3000 (Next); next.config.ts falls back to :8000 with a warning.
#
# Use the same hostname style everywhere (localhost vs 127.0.0.1).
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"
# GraphQL endpoint (defaults to ${NEXT_PUBLIC_BACKEND_URL}/graphql if unset)
NEXT_PUBLIC_GRAPHQL_URL="http://localhost:8000/graphql"
# EC2 ai.backend (production API on port 8000; set CORS_ORIGINS on the API to match this app origin):
# NEXT_PUBLIC_BACKEND_URL="http://54.146.221.133:8000"
# NEXT_PUBLIC_GRAPHQL_URL="http://54.146.221.133:8000/graphql"
# BACKEND_GRAPHQL_URL="http://54.146.221.133:8000/graphql"
# Signed storage GETs use same-origin /files/* → ai.backend (proxied in all environments).

# Desktop AI bar (WebSocket JSON-RPC to ${NEXT_PUBLIC_BACKEND_URL}/ws/gateway).
# Default LLM provider/model for chat.completions when the UI does not override (Ollama CPU stack).
NEXT_PUBLIC_CHAT_PROVIDER=ollama
NEXT_PUBLIC_CHAT_MODEL=steamdj/llama3.1-cpu-only
# Optional: WebSocket ?api_key= for local testing without a JWT (same key the backend accepts).
# NEXT_PUBLIC_AI_WS_API_KEY=""

# Optional: introspection URL for `npm run codegen` (defaults to NEXT_PUBLIC_GRAPHQL_URL in scripts).
CODEGEN_SCHEMA_URL="http://localhost:8000/graphql"

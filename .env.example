# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ai.backend — GraphQL, WebSocket, and storage are called directly from the browser (CORS + JWT).
# Use the same hostname style everywhere (localhost vs 127.0.0.1) and list both in ai.backend CORS_ORIGINS.
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"
# GraphQL endpoint (defaults to ${NEXT_PUBLIC_BACKEND_URL}/graphql if unset)
NEXT_PUBLIC_GRAPHQL_URL="http://localhost:8000/graphql"
# Signed storage GETs use same-origin /files/* rewrites to ai.backend (see next.config.ts).

# Desktop AI bar (WebSocket JSON-RPC to ${NEXT_PUBLIC_BACKEND_URL}/ws/gateway).
# Default LLM provider/model for chat.completions when the UI does not override (Ollama CPU stack).
NEXT_PUBLIC_CHAT_PROVIDER=ollama
NEXT_PUBLIC_CHAT_MODEL=steamdj/llama3.1-cpu-only
# Optional: WebSocket ?api_key= for local testing without a JWT (same key the backend accepts).
# NEXT_PUBLIC_AI_WS_API_KEY=""

# Optional: introspection URL for `npm run codegen` (defaults to NEXT_PUBLIC_GRAPHQL_URL in scripts).
CODEGEN_SCHEMA_URL="http://localhost:8000/graphql"
